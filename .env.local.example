# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# Stripe Price IDs (create these in your Stripe dashboard)
STRIPE_PRICE_FREQUENT_FAMILY=price_xxxxx
STRIPE_PRICE_WEEKDAY_FAMILY=price_xxxxx
STRIPE_PRICE_WEEKEND_FAMILY=price_xxxxx
STRIPE_PRICE_FREQUENT_SINGLE=price_xxxxx
STRIPE_PRICE_WEEKDAY_SINGLE=price_xxxxx
STRIPE_PRICE_WEEKEND_SINGLE=price_xxxxx
STRIPE_PRICE_DROP_IN=price_xxxxx

# Sanity
NEXT_PUBLIC_SANITY_PROJECT_ID=your_sanity_project_id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_TOKEN=your_sanity_api_token

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
